    "headline": "schema:headline",
    "publishedAt": "schema:datePublished",
    "body": "schema:articleBody",
    "season": "stats:season",
    "wins": "stats:wins",
    "losses": "stats:losses",
    "winPct": "stats:winPercentage",
    "points": "stats:points"
  }
